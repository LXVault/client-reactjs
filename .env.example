# Copy to `.env` to override. Every value also has a fallback in the code.

# ORIGIN of the Express backend (NO /api suffix) — the client appends /api
# itself. Set this to the backend's URL when it lives on a different origin,
# e.g. https://your-backend.onrender.com. Leave empty for a same-origin base
# (the Vite dev server proxies /api to VITE_PROXY_TARGET below).
VITE_API_URL=

# Dev-only: where the Vite dev server proxies /api to.
VITE_PROXY_TARGET=http://localhost:4000

# Dev/preview server port.
FRONTEND_PORT=5173
