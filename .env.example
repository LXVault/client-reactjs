# Copy to `.env` to override. Every value also has a fallback in the code.

# Base URL of the Express backend API. Defaults to the relative `/api`, which
# is reverse-proxied to the backend by nginx (prod) or the Vite dev server.
# Only set an absolute URL if the API lives on a different origin.
VITE_API_URL=/api

# Dev-only: where the Vite dev server proxies /api to.
VITE_PROXY_TARGET=http://localhost:4000

# Dev/preview server port.
FRONTEND_PORT=5173
